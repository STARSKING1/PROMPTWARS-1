# UrbanGuard Live — Server Environment Configuration
# Duplicate this file to '.env' and fill in your keys.

# PORT for the Express API
PORT=3000

# GOOGLE MAPS PLATFORM API KEY
# Must have 'Maps JavaScript API', 'Places API', 'Directions API' and 'Distance Matrix API' enabled.
GOOGLE_MAPS_API_KEY=YOUR_PROJECT_API_KEY_HERE

# SECURITY: Secret for salt/pepper in anonymization (Optional but recommended)
ANONYMIZATION_SALT=guardian_quantum_salt_2026
